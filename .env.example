# ===== Domínio público (DNS deve apontar pra VPS) =====
DOMAIN=seudominio.com

# ===== Postgres =====
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=troque-essa-senha-agora
POSTGRES_DB=portfolio_auth

# ===== JWT =====
# Gerar com: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ===== Cloudinary =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== URLs públicas =====
# CORS liberado pro frontend
FRONTEND_URL=https://seudominio.com
# Embutido no build do frontend (Vite)
VITE_API_URL=https://seudominio.com/api/v1

# ===== Dev local / Claude Code MCP (NÃO usado em produção) =====
# Token da API Hostinger lido pelo .mcp.json em ${HOSTINGER_API_TOKEN}.
# O docker-compose NÃO consome essa variável — ela só precisa estar
# exportada no shell onde você roda o Claude Code. Se o seu shell não
# carrega o .env automaticamente, exporte com:
#   set -a && source .env && set +a
# ou adicione `export HOSTINGER_API_TOKEN=...` ao ~/.bashrc.
HOSTINGER_API_TOKEN=
