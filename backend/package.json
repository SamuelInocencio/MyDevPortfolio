{
  "name": "portfolio-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate:mongo": "prisma generate --schema prisma/mongo/schema.prisma",
    "prisma:generate:postgres": "prisma generate --schema prisma/postgres/schema.prisma",
    "prisma:push:mongo": "prisma db push --schema prisma/mongo/schema.prisma",
    "prisma:migrate:postgres": "prisma migrate dev --schema prisma/postgres/schema.prisma",
    "prisma:seed": "tsx prisma/postgres/seed.ts",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src"
  },
  "prisma": {
    "seed": "tsx prisma/postgres/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
